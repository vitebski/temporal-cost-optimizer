{
  "manifest_version": 3,
  "name": "Temporal Cost Analyser",
  "version": "0.1.0",
  "description": "Adds a Cost Analyser view to the Temporal UI sidebar",
  "content_scripts": [
    {
      "matches": ["https://temporal.ternary.app/*", "https://*.temporal.io/*", "http://localhost/*", "http://localhost:*/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
